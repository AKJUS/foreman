          placeholder="Username"
          type="text"
          value=""
        />
      </FormGroup>
      <FormGroup
        fieldId="password"
        isRequired={true}
      >
        <TextInput
          autoComplete="current-password"
          id="login_password"
          isRequired={true}
          name="login[password]"
          onChange={[Function]}
          ouiaId="login-password"
          placeholder="Password"
          type="password"
          value=""
        />
      </FormGroup>
      <input
        name="authenticity_token"
        type="hidden"
        value="some token"
      />
      <ActionGroup>
        <Button
